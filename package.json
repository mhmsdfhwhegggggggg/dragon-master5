{
  "name": "app-template",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:metro\" \"npm run dev:worker\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port ${EXPO_PORT:-8081}",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:worker": "esbuild server/worker.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/worker.js",
    "start": "echo '[DB] Syncing schema...' && drizzle-kit push --force && cross-env NODE_ENV=production node dist/index.js",
    "start:worker": "cross-env NODE_ENV=production node dist/worker.js",
    "start:free-tier": "concurrently -n \"API,WORKER\" -c \"cyan,magenta\" \"npm run start\" \"npm run start:worker\"",
    "dev:worker": "cross-env NODE_ENV=development tsx watch server/worker.ts",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs",
    "license:generate": "tsx scripts/license-cli.ts generate",
    "license:activate": "tsx scripts/license-cli.ts activate",
    "license:status": "tsx scripts/license-cli.ts status",
    "license:deactivate": "tsx scripts/license-cli.ts deactivate",
    "license:hardware": "tsx scripts/license-cli.ts hardware",
    "build:protected": "npm run build && webpack --config webpack.obfuscate.config.js",
    "start:protected": "cross-env NODE_ENV=production node dist-obfuscated/index.js",
    "integrity:generate": "tsx -e \"import {IntegrityChecker} from './server/_core/integrity-checker'; IntegrityChecker.generateManifest('./integrity-manifest.json');\"",
    "build:dev": "eas build --platform android --profile development",
    "build:prod": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^1.0.0",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "11.10.0",
    "@trpc/react-query": "11.10.0",
    "@trpc/server": "11.10.0",
    "@types/pg": "^8.11.0",
    "axios": "^1.6.0",
    "bullmq": "^5.0.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.0",
    "cookie": "^0.6.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.44.7",
    "expo": "~52.0.28",
    "expo-audio": "~0.2.0",
    "expo-build-properties": "~0.13.2",
    "expo-constants": "~17.0.5",
    "expo-font": "~13.0.3",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.4",
    "expo-keep-awake": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-notifications": "~0.29.13",
    "expo-router": "~4.0.17",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.27.6",
    "expo-status-bar": "~2.0.1",
    "expo-symbols": "~0.2.2",
    "expo-system-ui": "~4.0.8",
    "expo-video": "~2.0.5",
    "expo-web-browser": "~14.0.2",
    "express": "^4.19.0",
    "ioredis": "^5.4.0",
    "javascript-obfuscator": "^4.1.0",
    "jose": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.0.0",
    "nanoid": "^5.0.0",
    "nativewind": "^4.0.0",
    "node-machine-id": "^1.1.12",
    "openai": "^4.0.0",
    "pg": "^8.11.0",
    "postgres": "^3.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.6",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.0",
    "react-native-worklets": "0.5.1",
    "superjson": "^2.0.0",
    "tailwind-merge": "^2.3.0",
    "telegram": "^2.26.0",
    "webpack-obfuscator": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.0",
    "@types/react": "~18.3.0",
    "better-sqlite3": "^11.5.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.23.0",
    "eslint": "^8.0.0",
    "eslint-config-expo": "~9.0.0",
    "prettier": "^3.3.0",
    "qrcode": "^1.5.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "~5.3.0",
    "vitest": "^2.1.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
